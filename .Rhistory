# ---- Define Functions ----
get_context <- function(chr, pos, ref_genome) {
if (!(chr %in% names(ref_genome))) return(NA)
# Extract 3bp region
seq <- subseq(ref_genome[[chr]], pos-1, pos+1)
as.character(seq)
}
